# Kopyala: cp .env.example .env  (Windows: copy .env.example .env)
# .env repoya gitmez. Lokalde main.py / railway_main.py baslarken otomatik yuklenir (python-dotenv).
# Railway'de Variables sekmesine ayni anahtarlari tek tek ekle.

# --- Zorunlu (bot) ---
TELEGRAM_BOT_TOKEN=

# Google Cloud Vision (foto/PDF OCR icin; bossa foto isleme hata verebilir)
VISION_API_KEY=

# --- Yetki (bos = herkes kullanabilir) ---
# Virgul veya boslukla birden fazla chat id
AUTHORIZED_CHAT_IDS=

# --- Opsiyonel: OCR ciktisini ek chat'e ilet ---
FORWARD_CHAT_ID=

# --- Opsiyonel: Oto yonlendirme sadece bu chat'ten gelsin (bos = kisit yok) ---
FORWARD_ONLY_SOURCE_CHAT_ID=

# --- Dosya yollari (varsayilan: proje kokundeki dosya adlari) ---
# PERSON_LIST_FILE=person_list.txt
# ACCOUNTS_RAW_FILE=hesaplar.txt
# ACCOUNTS_FORMATTED_FILE=hesaplar_formatted.txt
# FORWARDING_CONFIG_FILE=forwarding_config.json

# --- Telethon oto yonlendirme (forwarding_config.json yerine / uzerine yazar) ---
# true / false / 1 / 0
FORWARDING_ENABLED=false
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION_NAME=forwarding_user
TELETHON_PHONE=

# Tum forwarding JSON'unu tek satirda (cift tirnak icinde escape; Railway'de multiline zor)
# FORWARDING_CONFIG_JSON={"enabled":true,"api_id":"123","api_hash":"...","session_name":"forwarding_user"}
